{
  "name": "cocktails",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:style": "stylelint \"src/**/*.{vue,scss,css}\" --fix",
    "lint:fix": "eslint . --fix && npm run lint:style",
    "format": "prettier --write src/",
    "deploy": "npm run lint:fix && npm run build && npx gh-pages -d dist -e cocktails",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "element-plus": "^2.13.5",
    "normalize.css": "^8.0.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "gh-pages": "^6.3.0",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "stylelint": "^17.4.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "vite": "^7.3.1",
    "vite-plugin-eslint2": "^5.0.5",
    "vite-plugin-vue-devtools": "^8.0.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
